# DiscountRate
DISCOUNT_RATE=0.05

# Database
DATABASE_URL=sqlite+aiosqlite:///./earnings_engine.db
ENVIRONMENT=local
LOG_LEVEL=INFO

# Prices provider (Tradier)
PROVIDER_NAME=tradier
TRADIER_ACCESS_TOKEN=
TRADIER_BASE_URL=https://api.tradier.com
TRADIER_TIMEOUT=30
TRADIER_MAX_RETRIES=3
TRADIER_RATE_LIMIT=120

# Fundamentals (FMP)
FUNDAMENTALS_PROVIDER=fmp
FMP_API_KEY=
FMP_TIMEOUT=30
FMP_MAX_RETRIES=3

# Options provider (TastyTrade)
OPTIONS_PROVIDER=tastytrade
TT_USERNAME=
TT_PASSWORD=
TT_CLIENT_ID=
TT_CLIENT_SECRET=
TT_REFRESH_TOKEN=
TT_ENV=prod
TT_TIMEOUT_SECONDS=30

# FRED
FRED_API_KEY=

# Data settings
STRICT_LIVE_DATA=false
ALLOW_SIMULATION=true
UNIVERSE_SOURCE=STATIC

# Operating mode
OPERATING_MODE=GRACEFUL

# CORS
CORS_ORIGINS=["http://localhost:3000"]
