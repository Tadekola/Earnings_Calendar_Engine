# Earnings Calendar Engine — Environment Configuration
# Copy this to .env and fill in your values

# Core
ENVIRONMENT=local                    # local | staging | production
OPERATING_MODE=GRACEFUL              # STRICT | GRACEFUL
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./earnings_engine.db

# Data Settings
STRICT_LIVE_DATA=false
ALLOW_SIMULATION=true
UNIVERSE_SOURCE=sp500

# FMP (Financial Modeling Prep) — earnings + price data
FMP_API_KEY=
FMP_TIMEOUT=10
FMP_MAX_RETRIES=3

# Tradier — options chain data
TRADIER_ACCESS_TOKEN=
TRADIER_TIMEOUT=10
TRADIER_MAX_RETRIES=3

# TastyTrade (future)
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
